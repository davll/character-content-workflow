{
  "name": "character-content-workflow-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:skill": "tsx scripts/build-skills.ts",
    "build:generate-image-skill": "tsx scripts/build-generate-image-skill.ts",
    "build:character-registry-skill": "tsx scripts/build-character-registry-skill.ts",
    "build:style-registry-skill": "tsx scripts/build-style-registry-skill.ts",
    "sync:agents-skills": "tsx scripts/sync-agents-skills.ts",
    "build": "npm --workspaces run build",
    "test": "npm --workspaces run test --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "commander": "^15.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
